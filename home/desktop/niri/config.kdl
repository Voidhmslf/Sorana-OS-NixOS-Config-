// Sorana OS - Main Profile 🦊
include "base.kdl"

// Настройки мониторов
output "eDP-1" {
    mode "1920x1080@144.000"
    scale 1.0
    transform "normal"
    position x=0 y=0
}

output "HDMI-A-1" {
    mode "1920x1080@165.002" 
    scale 1.0
    position x=1920 y=0
}

// Анимации сделаем плавными, как движения лисьего хвоста
animations {
    // slowdown 2.0
}
