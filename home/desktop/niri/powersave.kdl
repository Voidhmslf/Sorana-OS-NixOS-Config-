// Sorana OS - Powersave Profile 🔋
include "base.kdl"

output "eDP-1" {
    mode "1920x1080@60.001"
    scale 1.0
    transform "normal"
    position x=0 y=0
}

output "HDMI-A-1" {
    mode "1920x1080@60.000"
    scale 1.0
    position x=1920 y=0
}

animations {
    // Включаем "медленные" анимации, чтобы они были мгновенными
    slowdown 0.0
}
